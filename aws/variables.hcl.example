# Required variables
region                    = "AWS_REGION"

# Base Ubuntu 22.04 AMI for the chosen region.
# Find the latest ID with:
#   aws ec2 describe-images --owners 099720109477 \
#     --filters 'Name=name,Values=ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*' \
#     --query 'sort_by(Images,&CreationDate)[-1].ImageId' --region AWS_REGION
ami                       = "AMI_ID"

# These variables will default to the values shown
# and do not need to be updated unless you want to
# change them
# domain                  = "global"
# datacenter              = "dc1"
# allowlist_ip            = "0.0.0.0/0"
# name_prefix             = "nomad"
# server_instance_type    = "t2.micro"
# server_count            = "3"
# client_instance_type    = "t2.medium"
# public_client_count     = "1"
# client_count            = "3"