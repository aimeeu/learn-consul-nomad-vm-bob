[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=~/.ssh/your-key.pem
ansible_python_interpreter=/usr/bin/python3

[servers]
server-1 ansible_host=10.0.1.10
server-2 ansible_host=10.0.1.11
server-3 ansible_host=10.0.1.12

[clients]
client-1 ansible_host=10.0.2.10
client-2 ansible_host=10.0.2.11
client-3 ansible_host=10.0.2.12

[public_clients]
public-client-1 ansible_host=10.0.3.10